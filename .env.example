# 광고 환경 설정
# .env.local 파일을 별도로 만들어 채워 주세요 (gitignore 대상)

# 광고 환경 설정
# test        → Toss Ads 테스트 전용 광고 ID 사용
# production  → 실제 발급된 프로덕션 광고 ID 사용 (ait.v2.live.*)
# 미설정       → 개발 빌드(vite dev)이면 test, 프로덕션 빌드(vite build)이면 production 자동 적용
VITE_AD_ENV=production

# 리워드 광고 ID — 광고 시청 후 새로운 부적 뽑기 (재뽑기)
# 미설정 시 하드코딩된 프로덕션 ID(ait.v2.live.5c06ff01e75a4884) 사용
VITE_REWARD_AD_ID=ait.v2.live.5c06ff01e75a4884

# 배너 광고 ID — 기록 페이지 하단 노출형 배너
# 미설정 시 하드코딩된 프로덕션 ID(ait.v2.live.41ce280c1bfe4683) 사용
VITE_BANNER_AD_ID=ait.v2.live.41ce280c1bfe4683
